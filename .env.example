# cash-buyer-scraper — environment variables
#
# Copy this file to one of:
#   - <repo>/.env                (loaded by your shell / tooling)
#   - ~/.openclaw/.env           (the repo also reads from here as a fallback)
#
# Tokens marked REQUIRED block one or more CLI commands when absent.
# Tokens marked OPTIONAL only kick in for specific subcommands.


# -------------------------------------------------------------------------
# Tranchi — the production endpoint we push cash buyers + leads to.
# -------------------------------------------------------------------------
#
# REQUIRED for: push-tranchi, push-tranchi-leads, tranchi-backfill-photos.
# This is the same `LEADS_API_KEY` value Tranchi configures on their side
# (per `Cash Buyer Pool Upload API — Documentation.md`). Ask the Tranchi
# team to issue you one tied to the cash-buyer-scraper integration.
TRANCHI_TOKEN=


# -------------------------------------------------------------------------
# Dispenser HTTP service — protects POST /api/dispense + related routes.
# -------------------------------------------------------------------------
#
# REQUIRED for: cash-buyer-intel serve.
# Generate a strong random value, e.g.
#   python -c 'import secrets; print(secrets.token_urlsafe(32))'
# Multiple tokens can be comma-separated for per-tenant identification:
#   DISPENSER_TOKEN=tranchi-prod-xxx,internal-ops-yyy
DISPENSER_TOKEN=


# -------------------------------------------------------------------------
# BatchData — source of cash-buyer search + skip-trace.
# -------------------------------------------------------------------------
#
# REQUIRED for: sync-batchdata, enrich-batchdata (and any dispenser job
# that needs to fetch fresh records on a cache miss).
#
# Set this in `batchdata-pp-cli` directly rather than as an env var here:
#   batchdata-pp-cli auth set-token <key>
# The dispenser doesn't read BATCHDATA_API_KEY itself — it subprocesses
# out to batchdata-pp-cli, which holds its own auth store. This entry is
# documented here just so operators know where the dependency comes from.
#
# Top up the wallet at https://app.batchdata.com — skip-trace pricing is
# observed at ~$0.077 per fully-enriched record (phone + email).
BATCHDATA_API_KEY=


# -------------------------------------------------------------------------
# BrightData — Zillow PDP scraping for the photo-enrichment waterfall.
# -------------------------------------------------------------------------
#
# OPTIONAL — only needed for: enrich-photos, enrich-zestimate,
# upgrade-photos-zillow. Without it those commands fall back to
# Street View / Esri aerial photos (which are no longer accepted by
# tranchi.ai's listing-CDN allowlist as of v0.13).
BRIGHTDATA_TOKEN=


# -------------------------------------------------------------------------
# Google Maps — Street View + Static Maps for the photo waterfall fallback.
# -------------------------------------------------------------------------
#
# OPTIONAL — only used by: enrich-photos (Street View / Esri fallback).
# Photos sourced from Google Maps are rejected by tranchi.ai's listing-CDN
# allowlist, so this is essentially legacy now.
#
# The repo also accepts this key from `~/.openclaw/.google_maps_api_key`
# as a fallback location.
GOOGLE_MAPS_KEY=


# -------------------------------------------------------------------------
# PP CLI database paths (advanced — usually leave unset).
# -------------------------------------------------------------------------
#
# The repo ATTACHes the Printing-Press CLI source DBs at query time.
# Defaults match the PP convention: ~/.local/share/<name>-pp-cli/data.db.
# Override only if you've moved them (e.g. via `<cli> --db <path>`):
#
# CASH_BUYER_INTEL_ATTOM_DB=/custom/path/attom.db
# CASH_BUYER_INTEL_BATCHDATA_DB=/custom/path/batchdata.db
# CASH_BUYER_INTEL_GOOGLEMAPS_DB=/custom/path/googlemaps.db
# CASH_BUYER_INTEL_TRANCHI_DB=/custom/path/tranchi.db
# CASH_BUYER_INTEL_BLOOIO_DB=/custom/path/blooio.db
# CASH_BUYER_INTEL_CENSUS_DB=/custom/path/census.db
